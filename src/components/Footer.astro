---
import guayaba from "@/assets/images/guayaba-cover.png";
import IconGithub from "@/assets/github.svg";
import IconInstagram from "@/assets/instagram.svg";
import { Image } from "astro:assets";
---

<footer
    class="relative bg-linear-to-br from-primary/10 to-secondary/10 py-12 overflow-hidden"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 justify-items-center">
            <div class="flex flex-col items-center md:items-start space-y-4">
                <div
                    class="relative w-40 h-20 bg-white/50 backdrop-blur-sm rounded-3xl shadow-lg"
                >
                    <Image
                        alt="Guayaba Devs Logo"
                        data-nimg="fill"
                        class="object-contain absolute inset-0 h-full w-full"
                        src={guayaba}
                    />
                </div>
                <p
                    class="text-gray-300 text-center md:text-left text-sm lg:text-base max-w-xs"
                >
                    Comunidad de desarrolladores que conectan, colaboran y
                    aprenden juntos.
                </p>
            </div><div
                class="flex flex-col items-center md:items-start space-y-3"
            >
                <h3
                    class="text-lg lg:text-xl font-bold bg-primary bg-clip-text text-transparent"
                >
                    Explorar
                </h3>
                <a
                    href="#nosotros"
                    class="text-gray-300 hover:text-primary transition-colors text-sm lg:text-base"
                    >Inicio</a
                ><a
                    href="#miembros"
                    class="text-gray-300 hover:text-primary transition-colors text-sm lg:text-base"
                    >Miembros</a
                ><a
                    href="#newsletter"
                    class="text-gray-300 hover:text-primary transition-colors text-sm lg:text-base"
                    >NewsLetter</a
                ><a
                    href="#post"
                    class="text-gray-300 hover:text-primary transition-colors text-sm lg:text-base"
                    >Eventos</a
                >
            </div>
            <div class="flex flex-col items-center md:items-start space-y-4">
                <h3
                    class="text-lg lg:text-xl bg-primary bg-clip-text text-transparent"
                >
                    Conéctate
                </h3>
                <div class="flex space-x-6 group">
                    <a
                        href="https://github.com/Guayaba-Devs"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-2 rounded-full bg-white/5 backdrop-blur-sm border border-white/10 group-hover:border-primary/30 transition-all"
                        tabindex="0"
                    >
                        <IconGithub />
                    </a>
                    <a
                        href="https://www.instagram.com/guayaba_devs_official/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-2 rounded-full bg-white/5 backdrop-blur-sm border border-white/10 group-hover:border-primary/30 transition-all"
                        tabindex="0"
                    >
                        <IconInstagram />
                    </a>
                </div>
            </div>
        </div>
        <div
            class="my-8 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"
        >
        </div>
        <div class="text-center text-sm text-gray-300">
            © <!-- -->2025<!-- --> Guayaba Devs. Todos los derechos reservados.
        </div>
    </div>
</footer>

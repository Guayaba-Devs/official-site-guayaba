---
import ListMembers from "@/components/ListMembers.astro";
---

<section
    id="team-section"
    class="w-full min-h-screen relative overflow-hidden bg-linear-to-br from-primary via-black to-secondary"
>
    <!-- Blur effect applied to the background -->
    <div class="absolute inset-0 backdrop-blur-md bg-black/30"></div>

    <div class="relative container mx-20 px-4 sm:px-6 lg:px-8 py-6">
        <!-- Content remains visible above the blur -->
        <div id="team-header" class="relative p-8 opacity-0">
            <div
                class="absolute -inset-2 bg-gradient-to-r from-primary to-secondary blur-2xl opacity-30 group-hover:opacity-50 transition-all duration-500"
            >
            </div>
            <h3
                class="text-5xl md:text-7xl lg:text-8xl font-bold bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent"
            >
                Miembros
            </h3>
            <p class="mt-4 text-2xl text-gray-300 max-w-2xl">
                El corazón palpitante de Guayabadevs. Conoce al equipo que está
                revolucionando la formación de desarrolladores.
            </p>
        </div>
    </div>

    <div
        id="team-carousel"
        class="flex w-full overflow-x-scroll overscroll-x-auto py-10 md:pt-8 pb-20 scroll-smooth [scrollbar-width:none] opacity-0"
    >
        <ListMembers />
    </div>
</section>

<script>
    import { createIntersectionAnimation } from "@/utils/animation";

    document.addEventListener("DOMContentLoaded", () => {
        createIntersectionAnimation("#team-header", {
            opacity: 1,
            x: 0,
            duration: 0.8,
            ease: "back.out(1.5)",
            transformOrigin: "left center",
        });

        createIntersectionAnimation("#team-carousel", {
            opacity: 1,
            y: 0,
            duration: 1,
            ease: "power3.out",
        });
    });
</script>

---
import ListMembers from "./ListMembers.astro";
---

<section
    class="w-full min-h-screen relative overflow-hidden bg-gradient-to-br from-primary via-black to-secondary"
>
    <!-- Blur effect applied to the background -->
    <div class="absolute inset-0 backdrop-blur-md bg-black/30"></div>

    <div class="relative container mx-auto px-4 sm:px-6 lg:px-8 py-24">
        <!-- Content remains visible above the blur -->
        <div class="relative p-8">
            <h3
                class="text-5xl md:text-7xl lg:text-8xl font-bold bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent"
            >
                Miembros
            </h3>
            <p class="mt-4 text-2xl text-gray-300 max-w-2xl">
                El corazón palpitante de Guayabadevs. Conoce al equipo que está
                revolucionando la formación de desarrolladores.
            </p>
        </div>
    </div>

    <div
        class="relative flex w-full overflow-x-scroll overscroll-x-auto py-10 md:py-20 scroll-smooth [scrollbar-width:none]"
    >
        <ListMembers />
    </div>
</section>

---
const { title, description, link, class: itemClass = "" } = Astro.props;
---

<a
    href={link}
    target="_blank"
    rel="noopener noreferrer"
    class={`block ${itemClass}`}
>
    <div
        class="flex flex-col h-full bg-gray-900 rounded-lg shadow-md hover:shadow-xl transition duration-200 border border-gray-600 p-4 justify-between"
    >
        {/* Header slot (ej. imágenes) */}
        <div class="overflow-hidden">
            <slot />
        </div>

        {/* Pie de tarjeta: título y descripción */}
        <div class="content-wrapper transition duration-200">
            <div
                class="font-bold text-gray-200 dark:text-neutral-200 mb-2 mt-2 text-lg"
            >
                {title}
            </div>
            <div
                class="font-sans font-normal text-gray-200 text-sm dark:text-neutral-300"
            >
                {description}
            </div>
        </div>
    </div>
</a>

<script>
    import { gsap } from "gsap";
    // Add hover effect for each card's content
    document.addEventListener("DOMContentLoaded", () => {
        document
            .querySelectorAll(".content-wrapper")
            .forEach((contentWrapper) => {
                const parentLink = contentWrapper.closest("a");
                if (parentLink) {
                    parentLink.addEventListener("mouseenter", () => {
                        gsap.to(contentWrapper, {
                            x: 8,
                            duration: 0.2,
                        });
                    });

                    parentLink.addEventListener("mouseleave", () => {
                        gsap.to(contentWrapper, {
                            x: 0,
                            duration: 0.2,
                        });
                    });
                }
            });
    });
</script>

---
// Props for the component
interface Props {
    className?: string;
    reverse?: boolean;
    pauseOnHover?: boolean;
    vertical?: boolean;
    repeat?: number;
    speed?: number;
}

const {
    className = "",
    reverse = false,
    pauseOnHover = false,
    vertical = false,
    repeat = 4,
    speed = 40,
} = Astro.props;

// Helper function for class names
const classNames = (
    ...classes: (
        | string
        | boolean
        | undefined
        | null
        | { [key: string]: boolean }
    )[]
) => {
    return classes
        .filter(Boolean)
        .map((c) => {
            if (typeof c === "object") {
                return Object.entries(c)
                    .filter(([_, value]) => Boolean(value))
                    .map(([key]) => key)
                    .join(" ");
            }
            return c;
        })
        .join(" ")
        .trim();
};
---

<!-- Main container with mask fade applied directly -->
<div class="marquee-outer mask-fade">
    <div
        class={classNames(
            `group flex overflow-x-hidden p-2 marquee-container`,
            {
                "flex-row": !vertical,
                "flex-col": vertical,
            },
            className,
        )}
        data-speed={speed}
        data-pause-on-hover={pauseOnHover}
        data-reverse={reverse}
        data-vertical={vertical}
    >
        {
            Array(repeat)
                .fill(0)
                .map((_, i) => (
                    <div
                        key={i}
                        class={classNames(
                            "flex shrink-0 justify-around marquee-content gap-4",
                            {
                                "marquee-horizontal": !vertical,
                                "marquee-vertical": vertical,
                                "marquee-reverse": reverse,
                                "marquee-pause-on-hover": pauseOnHover,
                            },
                        )}
                    >
                        <slot />
                    </div>
                ))
        }
    </div>
</div>

<style define:vars={{ speed: `${speed}s` }}>
    .marquee-outer {
        width: 100%;
        overflow: hidden;
        position: relative;
    }

    /* Fade mask using the exact code you provided */
    .mask-fade {
        /* WebKit */
        -webkit-mask-image: linear-gradient(
            90deg,
            transparent 0%,
            black 10%,
            black 90%,
            transparent 100%
        );
        /* estándar */
        mask-image: linear-gradient(
            90deg,
            transparent 0%,
            black 10%,
            black 90%,
            transparent 100%
        );
        mask-repeat: no-repeat;
    }

    .marquee-container {
        --gap: 1rem;
        gap: var(--gap);
    }

    .marquee-content {
        gap: var(--gap);
        animation-duration: var(--speed);
        animation-timing-function: linear;
        animation-iteration-count: infinite;
    }

    .marquee-horizontal {
        flex-direction: row;
        animation-name: marquee-horizontal;
    }

    .marquee-vertical {
        flex-direction: column;
        animation-name: marquee-vertical;
    }

    .marquee-reverse {
        animation-direction: reverse;
    }

    .marquee-pause-on-hover {
        animation-play-state: running;
    }

    .marquee-pause-on-hover:hover {
        animation-play-state: paused;
    }

    @keyframes marquee-horizontal {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-100%);
        }
    }

    @keyframes marquee-vertical {
        0% {
            transform: translateY(0);
        }
        100% {
            transform: translateY(-100%);
        }
    }
</style>

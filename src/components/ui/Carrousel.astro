---
import CardMember from "@/components/CardMember.astro";
const { items } = Astro.props;
---

<div class="relative max-w-7xl mx-auto py-8">
    <!-- Contenedor del carrusel -->
    <div
        class="overflow-x-auto flex snap-x snap-mandatory scroll-smooth gap-6 px-6 hide-scrollbar"
        id="carousel"
    >
        {
            items.map((member, idx) => (
                <section
                    id={`slide-${idx}`}
                    key={idx}
                    class="flex-shrink-0 snap-center w-72 sm:w-80 md:w-96 p-4 rounded-2xl relative carousel-item"
                >
                    <CardMember
                        role={member.role}
                        name={member.name}
                        img={member.img}
                        socialLinks={member.socialLinks}
                    />
                </section>
            ))
        }
    </div>

    <!-- Contenedor de flechas: fuera del .map -->
    <div
        class="fixed bottom-4 right-4
        md:bottom-6 md:right-6
        z-20
        flex space-x-2
        bg-white/20 backdrop-blur-sm rounded-full"
    >
        <!-- Flecha anterior -->
        <button
            id="prevBtn"
            aria-label="Anterior"
            class="h-12 w-12 md:h-10 md:w-10 rounded-full
                bg-white/20 backdrop-blur-sm
                hover:bg-white/30
                flex items-center justify-center
                transition z-20 disabled:opacity-40 disabled:cursor-not-allowed"
            disabled
        >
            ◀
        </button>

        <!-- Flecha siguiente -->
        <button
            id="nextBtn"
            aria-label="Siguiente"
            class="h-12 w-12 md:h-10 md:w-10 rounded-full
            bg-white/20 backdrop-blur-sm
            hover:bg-white/30
            flex items-center justify-center
            transition z-20 disabled:opacity-40 disabled:cursor-not-allowed"
        >
            ▶
        </button>
    </div>
</div>

<style>
    /* Fade transition for cards */
    .carousel-item {
        transition: opacity 0.5s ease-in-out;
    }
</style>

<script>
    import { gsap } from "@/utils/gsap-core";

    export function initCarouselNavigation() {
        const carousel = document.getElementById("carousel");
        const prevBtn = document.getElementById("prevBtn");
        const nextBtn = document.getElementById("nextBtn");

        if (!carousel || !prevBtn || !nextBtn) return;

        // Crear contexto GSAP para el carrusel
        const ctx = gsap.context(() => {
            const SCROLL_AMOUNT = 300;
            const ANIMATION_DURATION = 0.5;
            const ANIMATION_EASE = "power2.out";
            let rafId = null;
            let items = [];
            let carouselRect = null;

            // 1. Configuración inicial
            gsap.set(".carousel-item", { opacity: 0.3 });

            // 2. Actualizar estados de botones
            const updateButtonStates = () => {
                const { scrollLeft, scrollWidth, clientWidth } = carousel;
                const maxScroll = scrollWidth - clientWidth;
                const threshold = 5;

                prevBtn.disabled = scrollLeft < threshold;
                nextBtn.disabled = scrollLeft >= maxScroll - threshold;

                gsap.to([prevBtn, nextBtn], {
                    opacity: prevBtn.disabled || nextBtn.disabled ? 0.4 : 1,
                    duration: 0.3,
                    ease: "power2.out",
                    overwrite: "auto",
                });
            };

            // 3. Actualizar caché de elementos
            const updateCache = () => {
                items = Array.from(document.querySelectorAll(".carousel-item"));
                carouselRect = carousel.getBoundingClientRect();
            };

            // 4. Manejar scroll optimizado
            const handleScroll = () => {
                if (!rafId) {
                    rafId = requestAnimationFrame(() => {
                        updateButtonStates();
                        updateItemsVisibility();
                        rafId = null;
                    });
                }
            };

            // 5. Visibilidad simplificada
            const updateItemsVisibility = () => {
                if (!items.length || !carouselRect) return;

                items.forEach((item) => {
                    const itemRect = item.getBoundingClientRect();
                    const isVisible =
                        itemRect.right > carouselRect.left + 50 &&
                        itemRect.left < carouselRect.right - 50;

                    gsap.to(item, {
                        opacity: isVisible ? 1 : 0.3,
                        duration: 0.3,
                        overwrite: "auto",
                    });
                });
            };

            // 6. Animación de scroll
            const animateScroll = (amount) => {
                gsap.to(carousel, {
                    scrollLeft: carousel.scrollLeft + amount,
                    duration: ANIMATION_DURATION,
                    ease: ANIMATION_EASE,
                    onUpdate: () => {
                        cancelAnimationFrame(rafId);
                        handleScroll();
                    },
                    onComplete: updateCache,
                });
            };

            // 7. Observador de cambios de tamaño
            const resizeObserver = new ResizeObserver(() => {
                updateCache();
                updateButtonStates();
            });
            resizeObserver.observe(carousel);

            // 8. Event listeners
            carousel.addEventListener("scroll", handleScroll);
            prevBtn.addEventListener("click", () =>
                animateScroll(-SCROLL_AMOUNT),
            );
            nextBtn.addEventListener("click", () =>
                animateScroll(SCROLL_AMOUNT),
            );

            // Inicialización
            updateCache();
            updateButtonStates();
            updateItemsVisibility();
        }, carousel); // Ámbito del contexto al carrusel

        // Limpieza automática
        return () => {
            ctx.revert();
            carousel.removeEventListener("scroll", handleScroll);
            if (rafId) cancelAnimationFrame(rafId);
        };
    }
</script>

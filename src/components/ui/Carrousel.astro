---
import CardMember from "@/components/CardMember.astro";
const { items } = Astro.props;
---

<div class="relative max-w-7xl mx-auto py-8">
    <!-- Contenedor del carrusel -->
    <div
        class="overflow-x-auto flex snap-x snap-mandatory scroll-smooth gap-6 px-6 hide-scrollbar"
        id="carousel"
    >
        {
            items.map((member, idx) => (
                <section
                    id={`slide-${idx}`}
                    key={idx}
                    class="flex-shrink-0 snap-center w-72 sm:w-80 md:w-96 p-4 rounded-2xl relative carousel-item"
                >
                    <CardMember
                        role={member.role}
                        name={member.name}
                        img={member.img}
                        socialLinks={member.socialLinks}
                    />
                </section>
            ))
        }
    </div>

    <!-- Contenedor de flechas: fuera del .map -->
    <div
        class="fixed bottom-4 right-4
        md:bottom-6 md:right-6
        z-20
        flex space-x-2
        bg-white/20 backdrop-blur-sm rounded-full"
    >
        <!-- Flecha anterior -->
        <button
            id="prevBtn"
            aria-label="Anterior"
            class="h-12 w-12 md:h-10 md:w-10 rounded-full
                bg-white/20 backdrop-blur-sm
                hover:bg-white/30
                flex items-center justify-center
                transition z-20 disabled:opacity-40 disabled:cursor-not-allowed"
            disabled
        >
            ◀
        </button>

        <!-- Flecha siguiente -->
        <button
            id="nextBtn"
            aria-label="Siguiente"
            class="h-12 w-12 md:h-10 md:w-10 rounded-full
            bg-white/20 backdrop-blur-sm
            hover:bg-white/30
            flex items-center justify-center
            transition z-20 disabled:opacity-40 disabled:cursor-not-allowed"
        >
            ▶
        </button>
    </div>
</div>

<style>
    /* Fade transition for cards */
    .carousel-item {
        transition: opacity 0.5s ease-in-out;
    }
</style>

<script>
    import { gsap } from "@/utils/gsap-core";

    document.addEventListener("DOMContentLoaded", () => {
        initCarouselNavigation();
    });

    function initCarouselNavigation() {
        // Cache DOM elements
        const carousel = document.getElementById("carousel");
        const prevBtn = document.getElementById("prevBtn");
        const nextBtn = document.getElementById("nextBtn");

        if (!carousel || !prevBtn || !nextBtn) return;

        // Constants for animations
        const SCROLL_AMOUNT = 300;
        const ANIMATION_DURATION = 0.5;
        const ANIMATION_EASE = "power2.out";

        // Initial states
        updateButtonStates();
        updateItemsVisibility();

        // Main functions
        function updateButtonStates() {
            const { scrollLeft, scrollWidth, clientWidth } = carousel;
            const maxScroll = scrollWidth - clientWidth;
            const threshold = 5;

            // Update button states
            prevBtn.disabled = scrollLeft < threshold;
            nextBtn.disabled = scrollLeft >= maxScroll - threshold;

            // Update visual state
            prevBtn.style.opacity = prevBtn.disabled ? "0.4" : "1";
            nextBtn.style.opacity = nextBtn.disabled ? "0.4" : "1";
        }

        function updateItemsVisibility() {
            const items = document.querySelectorAll(".carousel-item");
            const carouselRect = carousel.getBoundingClientRect();

            items.forEach((item) => {
                const rect = item.getBoundingClientRect();
                let opacity = 0.3;

                if (
                    rect.left >= carouselRect.left - 20 &&
                    rect.right <= carouselRect.right + 20
                ) {
                    // Fully visible
                    opacity = 1;
                } else if (
                    (rect.left < carouselRect.left &&
                        rect.right > carouselRect.left) ||
                    (rect.left < carouselRect.right &&
                        rect.right > carouselRect.right)
                ) {
                    // Partially visible - calculate ratio
                    const visibleWidth =
                        rect.left < carouselRect.left
                            ? rect.right - carouselRect.left
                            : carouselRect.right - rect.left;
                    opacity =
                        0.3 +
                        Math.max(0, Math.min(visibleWidth / rect.width, 1)) *
                            0.7;
                }

                gsap.to(item, {
                    opacity,
                    duration: ANIMATION_DURATION,
                    ease: ANIMATION_EASE,
                });
            });
        }

        // Event listeners
        carousel.addEventListener("scroll", () => {
            updateButtonStates();
            updateItemsVisibility();
        });

        // Button handlers with unified animation config
        function animateScroll(amount) {
            gsap.to(carousel, {
                scrollLeft: carousel.scrollLeft + amount,
                duration: ANIMATION_DURATION,
                ease: ANIMATION_EASE,
                onUpdate: updateButtonStates,
                onComplete: updateItemsVisibility,
            });
        }

        prevBtn.addEventListener("click", () => animateScroll(-SCROLL_AMOUNT));
        nextBtn.addEventListener("click", () => animateScroll(SCROLL_AMOUNT));

        // Initial visibility update with small delay
        setTimeout(updateItemsVisibility, 300);
    }
</script>

---
import { Image } from "astro:assets";

const { images } = Astro.props;

// Mapeo de anchos según número de imágenes
const widthMap: Record<number, string> = {
    1: "w-full",
    2: "md:w-1/2",
    3: "md:w-1/3",
    4: "md:w-1/2",
};
const heights = "h-40 md:h-64 lg:h-72";
---

<div class="flex flex-wrap md:flex-nowrap gap-2 p-2 overflow-hidden">
    {
        images.map((img) => (
            <div
                class={`relative ${widthMap[images.length] ?? "md:w-1/3"} ${heights}`}
            >
                <Image
                    src={img.src}
                    alt={img.alt ?? ""}
                    class="rounded-md object-cover"
                />
            </div>
        ))
    }
</div>

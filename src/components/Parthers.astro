---
// src/components/PartnersMarquee.astro
import { Image } from "astro:assets";
import notion from "../assets/parthers/notion-logo.png";
import tecmilenio from "../assets/parthers/NAO_Tecmilenio.png";
import github from "../assets/parthers/backpack.png";
import campusExpert from "../assets/parthers/github-campus-experts.svg";

const images = [
    { src: notion, alt: "Notion" },
    { src: tecmilenio, alt: "Tecmilenio" },
    { src: github, alt: "GitHub" },
    { src: campusExpert, alt: "Campus Expert" },
];

const repeated = [...images, ...images];
---

<div class="w-full bg-linear-to-r from-primary to-secondary py-8 md:py-12">
    <h2
        class="text-3xl text-center font-bold md:text-4xl lg:text-5xl mb-4 text-white"
    >
        Con el respaldo de líderes en la industria
    </h2>
    <p
        class="text-center text-lg md:text-xl text-gray-200 mt-4 max-w-2xl mx-auto"
    >
        Juntos fortalecemos la innovación y el crecimiento de la comunidad
        tecnológica
    </p>

    <!-- Marquee Wrapper -->
    <!-- TODO fix loop of animation -->
    <div class="w-full flex flex-nowrap overflow-hidden mask-fade group mt-10">
        <ul
            class="flex items-center justify-center md:justify-start
                 motion-safe:animate-marquee group-hover:paused"
        >
            {
                repeated.map((logo) => (
                    <li class="mx-8" key={logo.alt}>
                        <img
                            src={logo.src.src}
                            alt={logo.alt}
                            class="max-w-none h-12"
                        />
                    </li>
                ))
            }
        </ul>
        <ul
            class="flex items-center justify-center md:justify-start
                 motion-safe:animate-marquee group-hover:paused"
            aria-hidden="true"
        >
            {
                repeated.map((logo) => (
                    <li class="mx-8" key={logo.alt + "_dup"}>
                        <img
                            src={logo.src.src}
                            alt={logo.alt}
                            class="max-w-none h-12"
                        />
                    </li>
                ))
            }
        </ul>
    </div>
</div>
<style>
    /*– Fade en los bordes –*/
    .mask-fade {
        /* WebKit */
        -webkit-mask-image: linear-gradient(
            90deg,
            transparent 0%,
            black 10%,
            black 90%,
            transparent 100%
        );
        /* estándar */
        mask-image: linear-gradient(
            90deg,
            transparent 0%,
            black 10%,
            black 90%,
            transparent 100%
        );
        mask-repeat: no-repeat;
    }
</style>

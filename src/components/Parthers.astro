---
import { Image } from "astro:assets";
import Marquee from "@/components/ui/Marquee.astro";
import notion from "../assets/parthers/notion-logo.png";
import tecmilenio from "../assets/parthers/NAO_Tecmilenio.png";
import github from "../assets/parthers/backpack.png";
import campusExpert from "../assets/parthers/github-campus-experts.svg";

const logos = [
    { src: notion, alt: "Notion" },
    { src: tecmilenio, alt: "Tecmilenio" },
    { src: github, alt: "GitHub" },
    { src: campusExpert, alt: "Campus Expert" },
];
---

<section
    class="w-full bg-linear-to-r from-primary to-secondary py-8 md:py-12 overflow-x-hidden"
>
    <div
        class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center mb-8 md:mb-12"
    >
        <h2
            class="text-3xl font-bold md:text-4xl lg:text-5xl mb-4 text-white animate-on-scroll animate-slide-up"
        >
            Con el respaldo de líderes en la industria
        </h2>
        <p
            class="text-lg md:text-xl text-gray-200 mt-4 max-w-2xl mx-auto animate-on-scroll animate-fade-in-delayed"
        >
            Juntos fortalecemos la innovación y el crecimiento de la comunidad
            tecnológica
        </p>
    </div>

    <div
        class="relative w-full py-6 animate-on-scroll animate-fade-in-most-delayed"
    >
        <Marquee speed={45} fadeEdges={true} class="py-4">
            {
                logos.map((logo) => (
                    <div class="inline-block mx-4 md:mx-8 px-2 py-3 rounded-xl logo-item">
                        <Image
                            src={logo.src}
                            alt={logo.alt}
                            class="h-12 md:h-16 w-auto max-w-[160px] md:max-w-[350px] object-contain hover:grayscale-0 transition-all duration-300"
                        />
                    </div>
                ))
            }
        </Marquee>
    </div>
</section>

<style>
    /* Animation keyframes */
    @keyframes fade-in {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @keyframes slide-up {
        from {
            transform: translateY(20px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    /* Logo hover effect */
    .logo-item {
        transition: transform 0.3s;
    }

    .logo-item:hover {
        transform: scale(1.05);
    }

    .animate-on-scroll {
        opacity: 0;
        will-change: transform, opacity;
        animation-play-state: paused;
    }
    .animate-on-scroll.visible {
        opacity: 1;
        animation-play-state: running;
    }

    .animate-slide-up.visible {
        animation: slide-up 0.8s ease-out forwards;
    }
    .animate-fade-in-delayed.visible {
        animation: fade-in 0.8s ease-out 0.2s forwards;
    }
    .animate-fade-in-most-delayed.visible {
        animation: fade-in 0.8s ease-out 0.6s forwards;
    }
</style>

<script>
    // Optional: Add intersection observer for more controlled animations
    const observer = new IntersectionObserver(
        (entries, obs) => {
            for (const entry of entries) {
                if (entry.isIntersecting) {
                    entry.target.classList.add("visible");
                    obs.unobserve(entry.target);
                }
            }
        },
        { threshold: 0.2 },
    );

    document
        .querySelectorAll(".animate-on-scroll")
        .forEach((el) => observer.observe(el));
</script>

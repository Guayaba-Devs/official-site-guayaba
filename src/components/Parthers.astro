---
import { Image } from "astro:assets";
import Marquee from "@/components/ui/Marquee.astro";
import notion from "@/assets/parthers/notion-logo.png";
import tecmilenio from "@/assets/parthers/NAO_Tecmilenio.png";
import github from "@/assets/parthers/backpack.png";
import campusExpert from "@/assets/parthers/github-campus-experts.svg";

const logos = [
    { src: notion, alt: "Notion" },
    { src: tecmilenio, alt: "Tecmilenio" },
    { src: github, alt: "GitHub" },
    { src: campusExpert, alt: "Campus Expert" },
];
---

<section
    id="partners-section"
    class="w-full bg-linear-to-r from-primary to-secondary py-8 md:py-12 overflow-x-hidden"
>
    <div
        class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center mb-8 md:mb-12"
    >
        <h2
            id="partners-title"
            class="text-3xl font-bold md:text-4xl lg:text-5xl mb-4 text-white opacity-0 transform translate-y-4"
        >
            Con el respaldo de líderes en la industria
        </h2>
        <p
            id="partners-subtitle"
            class="text-lg md:text-xl text-gray-200 mt-4 max-w-2xl mx-auto opacity-0"
        >
            Juntos fortalecemos la innovación y el crecimiento de la comunidad
            tecnológica
        </p>
    </div>

    <div id="partners-marquee" class="relative w-full py-6 opacity-0">
        <Marquee speed={45} className="py-4">
            {
                logos.map((logo) => (
                    <div class="inline-block mx-4 md:mx-8 px-2 py-3 rounded-xl logo-item">
                        <Image
                            src={logo.src}
                            alt={logo.alt}
                            class="h-12 md:h-16 w-auto max-w-[160px] md:max-w-[350px] object-contain hover:grayscale-0 transition-all duration-300"
                        />
                    </div>
                ))
            }
        </Marquee>
    </div>
</section>

<style>
    /* Logo hover effect */
    .logo-item {
        transition: transform 0.3s;
    }

    .logo-item:hover {
        transform: scale(1.05);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Function to animate the Partners section
    function animatePartnersSection() {
        const partnersSection = document.getElementById("partners-section");
        if (!partnersSection) return;

        // Create a timeline for staggered animations
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#partners-section",
                start: "top 75%", // Start when the top of the section hits 75% from the top of viewport
                once: true, // Only trigger once
            },
        });

        // Animate title
        tl.to(
            "#partners-title",
            {
                y: 0,
                opacity: 1,
                duration: 0.8,
                ease: "back.out",
            },
            0,
        );

        // Animate subtitle
        tl.to(
            "#partners-subtitle",
            {
                opacity: 1,
                duration: 0.8,
                ease: "power3.out",
            },
            0.2,
        );

        // Animate marquee container
        tl.to(
            "#partners-marquee",
            {
                opacity: 1,
                duration: 0.8,
                ease: "power3.out",
            },
            0.6,
        );
    }

    // Wait for the page to be fully loaded
    document.addEventListener("DOMContentLoaded", animatePartnersSection);
</script>

---
import { Image } from "astro:assets";
import Marquee from "@/components/ui/Marquee.astro";
import notion from "../assets/parthers/notion-logo.png";
import tecmilenio from "../assets/parthers/NAO_Tecmilenio.png";
import github from "../assets/parthers/backpack.png";
import campusExpert from "../assets/parthers/github-campus-experts.svg";

const logos = [
    { src: notion, alt: "Notion" },
    { src: tecmilenio, alt: "Tecmilenio" },
    { src: github, alt: "GitHub" },
    { src: campusExpert, alt: "Campus Expert" },
];
---

<div
    class="w-full bg-linear-to-r from-primary to-secondary py-8 md:py-12 overflow-x-hidden animate-fade-in"
>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-8 md:mb-12 animate-slide-up">
            <h2
                class="text-3xl font-bold md:text-4xl lg:text-5xl mb-4 text-white animate-fade-in-delayed"
            >
                Con el respaldo de líderes en la industria
            </h2>
            <p
                class="text-lg md:text-xl text-gray-200 mt-4 max-w-2xl mx-auto animate-fade-in-more-delayed"
            >
                Juntos fortalecemos la innovación y el crecimiento de la
                comunidad tecnológica
            </p>
        </div>
    </div>

    <div class="relative w-full py-6 animate-fade-in-most-delayed">
        <!-- Remove this overlay since we now have the fade effect built into the Marquee -->
        <!-- <div class="absolute inset-0 bg-gradient-to-r from-primary/30 via-transparent to-secondary/30 z-20"></div> -->

        <Marquee speed={45} fadeEdges={true} className="py-4">
            {
                logos.map((logo, index) => (
                    <div class="inline-block mx-4 md:mx-8 px-2 py-3 rounded-xl logo-item">
                        <Image
                            src={logo.src}
                            alt={logo.alt}
                            class="h-12 md:h-16 w-auto max-w-[160px] md:max-w-[350px] object-contain hover:grayscale-0 transition-all duration-300"
                        />
                    </div>
                ))
            }
        </Marquee>
    </div>
</div>

<style>
    /* Animation keyframes */
    @keyframes fade-in {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @keyframes slide-up {
        from {
            transform: translateY(20px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    /* Animation classes */
    .animate-fade-in {
        animation: fade-in 0.8s ease-out forwards;
    }

    .animate-slide-up {
        animation: slide-up 0.8s ease-out forwards;
    }

    .animate-fade-in-delayed {
        animation: fade-in 0.8s ease-out 0.2s forwards;
        opacity: 0;
    }

    .animate-fade-in-more-delayed {
        animation: fade-in 0.8s ease-out 0.4s forwards;
        opacity: 0;
    }

    .animate-fade-in-most-delayed {
        animation: fade-in 0.8s ease-out 0.6s forwards;
        opacity: 0;
    }

    /* Logo hover effect */
    .logo-item {
        transition: transform 0.3s;
    }

    .logo-item:hover {
        transform: scale(1.05);
    }
</style>

<script>
    // Optional: Add intersection observer for more controlled animations
    document.addEventListener("DOMContentLoaded", () => {
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("visible");
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.2 },
        );

        // Observe elements that should animate on scroll
        document
            .querySelectorAll(
                ".animate-slide-up, .animate-fade-in-delayed, .animate-fade-in-more-delayed",
            )
            .forEach((el) => observer.observe(el));
    });
</script>

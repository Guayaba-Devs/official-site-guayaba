---
import { Image } from "astro:assets";
import notion from "../assets/parthers/notion-logo.png";
import tecmilenio from "../assets/parthers/NAO_Tecmilenio.png";
import github from "../assets/parthers/backpack.png";
import campusExpert from "../assets/parthers/github-campus-experts.svg";
const images = [
    { src: notion, alt: "Notion" },
    { src: tecmilenio, alt: "Tecmilenio" },
    { src: github, alt: "GitHub" },
    { src: campusExpert, alt: "Campus Expert" },
];

const repeated = [...images, ...images];
---

<div class="w-full bg-linear-to-r from-primary to-secondary py-8 md:py-12">
    <h2
        class="text-3xl text-center font-bold md:text-4xl lg:text-5xl mb-4 text-white"
    >
        Con el respaldo de líderes en la industria
    </h2>
    <p
        class="text-center text-lg md:text-xl text-gray-200 mt-4 max-w-2xl mx-auto"
    >
        Juntos fortalecemos la innovación y el crecimiento de la comunidad
        tecnológica
    </p>

    <!-- Aquí el wrapper del marquee -->
    <div
        class="mt-10
      relative
      overflow-hidden
      /* sólo animar si NO hay prefers-reduced-motion */
      motion-safe:[mask-image:linear-gradient(90deg,transparent,white_10%,white_90%,transparent)]"
    >
        <div
            class="flex
        whitespace-nowrap
        w-max
        motion-safe:animate-marquee"
        >
            {
                repeated.map((image, idx) => (
                    <span
                        key={idx}
                        class="inline-block px-4 flex-none"
                        {...(idx >= images.length
                            ? { "aria-hidden": "true" }
                            : {})}
                    >
                        <Image
                            src={image.src}
                            alt={image.alt}
                            class="h-12 w-auto object-contain hover:grayscale-0 transition duration-300"
                        />
                    </span>
                ))
            }
        </div>
    </div>
</div>

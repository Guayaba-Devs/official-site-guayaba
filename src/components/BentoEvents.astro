---
import HeaderImageBento from "@/components/HeaderImageBento.astro";
import BentoGridItem from "@/components/ui/BentoGridItem.astro";
import BentoGrid from "@/components/ui/BentoGrid.astro";

import cinsoft1 from "@/assets/events/cinsoft1.webp";
import cinsoft2 from "@/assets/events/cinsoft2.webp";
import cinsoft3 from "@/assets/events/cinsoft3.webp";
import guayabaday from "@/assets/events/guayabaday.webp";
import githubConnect from "@/assets/events/githubConnect.webp";
import compuFest1 from "@/assets/events/compu-fest.webp";
import compuFest2 from "@/assets/events/compu-fest2.webp";
interface EventItem {
    title: string;
    description: string;
    link: string;
    className: string;
    images: { src: ImageMetadata; alt?: string }[];
}

const items: EventItem[] = [
    {
        title: "CinSoft 4ta edición",
        description:
            "El pasado 30 de octubre, tuvimos el honor de representar a Guayaba Devs como comunidad en este increíble evento organizado en la Universidad Autónoma del Estado de Hidalgo (UAEH).",
        link: "https://www.instagram.com/p/DC-CDmFyz3r/?img_index=1",
        className: "md:col-span-2",
        images: [{ src: cinsoft1 }, { src: cinsoft2 }, { src: cinsoft3 }],
    },
    {
        title: "Guayaba Day",
        description:
            "El pasado 12 de septiembre en la ESCIHU, reunimos a expertos en programación y desarrollo.",
        link: "https://www.instagram.com/p/DAcMD2eOW3B/?img_index=3",
        className: "md:col-span-1",
        images: [{ src: guayabaday }],
    },
    {
        title: "Notion + GitHub Campus Connect",
        description:
            "Presentamos cómo las comunidades pueden usar Notion/GitHub y más novedades de Notion.",
        link: "https://www.instagram.com/p/C4l7mWsLsEP/?img_index=1",
        className: "md:col-span-1",
        images: [{ src: githubConnect }],
    },
    {
        title: "Compu-Fest[0]",
        description:
            "Para nosotros que las personas conecten con aquellas que tienen pasiones parecidas resulta sumamente valioso...",
        link: "https://www.instagram.com/p/DBDJYa1OC5I/",
        className: "md:col-span-2",
        images: [{ src: compuFest1 }, { src: compuFest2 }],
    },
];
---

<section
    id="events-section"
    class="w-full h-auto py-20 relative overflow-hidden"
>
    <h2
        id="events-title"
        class="text-4xl md:text-6xl font-bold bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent mb-12 text-center opacity-0 translate-x-[-50px]"
    >
        Nuestros Eventos
    </h2>

    <!-- Simply wrap the existing BentoGrid with a container for animation -->
    <div id="bento-container" class="opacity-0 translate-y-10">
        <BentoGrid
            class="w-full mx-auto md:auto-rows-[22rem] gap-6 pb-[2%]"
            id="events-grid"
        >
            {
                items.map((item, index) => (
                    <BentoGridItem
                        title={item.title}
                        description={item.description}
                        link={item.link}
                        class={`${item.className} bento-item opacity-0`}
                    >
                        <HeaderImageBento images={item.images} />
                    </BentoGridItem>
                ))
            }
        </BentoGrid>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    document.addEventListener("DOMContentLoaded", () => {
        initEventsAnimations();
    });

    function initEventsAnimations() {
        const eventsSection = document.getElementById("events-section");
        if (!eventsSection) return;

        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#events-section",
                start: "top 75%",
                once: true,
            },
        });

        // Slide in title from left (like slideIn in framer-motion)
        tl.to(
            "#events-title",
            {
                x: 0,
                opacity: 1,
                duration: 0.8,
                ease: "back.out(1.5)",
            },
            0.3,
        );

        // Fade in grid container
        tl.to(
            "#bento-container",
            {
                y: 0,
                opacity: 1,
                duration: 0.8,
                ease: "power3.out",
            },
            0.5,
        );

        // Staggered animation for grid items
        const gridItems = document.querySelectorAll(".bento-item");
        tl.to(
            gridItems,
            {
                opacity: 1,
                duration: 0.6,
                stagger: 0.15,
                ease: "power2.out",
            },
            0.7,
        );

        // Add hover effect to the grid container
        const gridContainer = document.getElementById("events-grid");
        if (gridContainer) {
            gridContainer.addEventListener("mouseenter", () => {
                gsap.to(gridContainer, {
                    scale: 1.02,
                    duration: 0.3,
                    ease: "power2.out",
                });
            });

            gridContainer.addEventListener("mouseleave", () => {
                gsap.to(gridContainer, {
                    scale: 1,
                    duration: 0.3,
                    ease: "power2.out",
                });
            });
        }
    }
</script>

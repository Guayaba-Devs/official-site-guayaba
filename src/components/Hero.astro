---
import { Image } from "astro:assets";
import petLogo from "@/assets/images/mascota.png";
import ArrowRight from "@/assets/arrow-right.svg";
import ArrowDown from "@/assets/arrow-down.svg";
---

<section
    id="hero-section"
    class="min-h-screen relative bg-background font-sans flex flex-col items-center justify-center tracking-tight"
>
    <!-- Grid background (adding this for the animation) -->
    <div id="grid-bg" class="absolute inset-0 bg-center opacity-0"></div>

    <!-- Glow izquierdo -->
    <div
        id="blob1"
        class="absolute inset-36 size-48 rounded-full bg-radial from-primary from-80% to-primary blur-3xl mix-blend-screen opacity-0 translate-y-[-20px]"
    >
    </div>
    <!-- Glow derecho -->
    <div
        id="blob2"
        class="absolute inset-x-[75%] size-48 rounded-full bg-radial from-secondary from-80% to-secondary mix-blend-screen blur-2xl opacity-0 translate-y-[-25px]"
    >
    </div>

    <div class="relative z-10 flex flex-col items-center space-y-4">
        <div id="logo-container" class="opacity-0 scale-0">
            <Image
                src={petLogo}
                alt="Mascota de guayaba"
                height={80}
                width={90}
                loading="lazy"
                fetchpriority="high"
            />
        </div>
        <h1
            id="title"
            class="opacity-0 translate-y-10 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-4 sm:mb-6 bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent"
        >
            Guayabadevs
        </h1>
        <p
            id="subtitle"
            class="opacity-0 translate-y-10 text-lg sm:text-xl md:text-2xl lg:text-3xl text-muted-foreground mb-8 sm:mb-12 font-medium max-w-2xl mx-auto px-2"
        >
            Creando desarrolladores
            <span class="text-primary font-bold">fructíferos</span>
        </p>
        <div id="buttons" class="flex gap-4 mt-4 opacity-0 translate-y-10">
            <a
                href="https://www.instagram.com/guayaba_devs_official/"
                target="_blank"
                rel="noopener noreferrer"
            >
                <button
                    class="px-6 py-2 bg-teal-400 rounded-full hover:bg-teal-500 flex items-center gap-2 transition-all transform hover:scale-105"
                >
                    Únete a la comunidad
                    <ArrowRight
                        id="arrow-right"
                        class="w-4 h-4 sm:w-5 sm:h-5 bg-white"
                    />
                </button>
            </a>

            <a
                href="https://www.instagram.com/guayaba_devs_official/"
                target="_blank"
                rel="noopener noreferrer"
            >
                <button
                    class="flex items-center gap-2 px-6 py-2 text-primary border border-teal-400 rounded-full hover:bg-teal-400/20 transition-all transform hover:scale-105"
                >
                    Próximos eventos
                    <ArrowDown class="w-4 h-4 sm:w-5 sm:h-5 bg-white" />
                </button>
            </a>
        </div>
    </div>
</section>

<script>
    import { gsap } from "@/utils/gsap-core";

    document.addEventListener("DOMContentLoaded", () => {
        // Create animation timeline once
        const tl = gsap.timeline({
            scrollTrigger: {
                trigger: "#hero-section",
                start: "top 75%",
                once: true,
            },
        });

        // Group animations by timing
        // Background elements
        tl.to(
            "#grid-bg",
            { opacity: 0.03, duration: 1, ease: "power3.out" },
            0.5,
        )
            .to(
                "#blob1, #blob2",
                { opacity: 0.8, duration: 1, ease: "power2.out" },
                0.5,
            )
            .to(
                "#logo-container",
                { scale: 1, opacity: 1, duration: 1, ease: "back.out" },
                0.5,
            );

        // Text elements with sequenced timing
        tl.to(
            "#title",
            { y: 0, opacity: 1, duration: 1.25, ease: "back.out" },
            0.8,
        )
            .to(
                "#subtitle",
                { y: 0, opacity: 1, duration: 1, ease: "power3.out" },
                1,
            )
            .to(
                "#buttons",
                { y: 0, opacity: 1, duration: 1, ease: "power3.out" },
                1.2,
            );

        // Continuous floating animations separate from the timeline
        gsap.to("#blob1", {
            y: "-20px",
            duration: 3,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
        });

        gsap.to("#blob2", {
            y: "-25px",
            duration: 4,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
            delay: 0.5,
        });

        gsap.to("#arrow-right", {
            x: "5px",
            duration: 0.8,
            repeat: -1,
            yoyo: true,
            ease: "power1.inOut",
        });
    });
</script>

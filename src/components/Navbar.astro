---
import { Image } from "astro:assets";
import logoGuayaba from "@/assets/images/guayaba-cover.png";
---

<header
    id="navbar"
    class="fixed top-0 w-screen z-30 bg-linear-to-r from-primary to-secondary transition-transform duration-300"
>
    <nav
        class="mx-auto flex items-center justify-between px-4 h-[4rem] lg:px-8"
    >
        <div class="flex items-center justify-between w-full">
            <Image
                src={logoGuayaba}
                alt="Guayaba Devs Logo"
                width={200}
                height={60}
                loading="lazy"
                fetchpriority="high"
            />
            <ul class="flex space-x-12 font-semibold">
                <li><a href="#nosotros">Nosotros</a></li>
                <li><a href="#miembros">Miembros</a></li>
                <li><a href="#newsletter">Newsletter</a></li>
                <li><a href="#post">Posts</a></li>
            </ul>
        </div>
    </nav>
</header>

<script>
    // Importar y ejecutar la función de inicialización del navbar
    import { initNavbarScroll } from "@/scripts/navbar";
    import { setupAnimations } from "@/scripts/animations";
    document.addEventListener("DOMContentLoaded", () => {
        initNavbarScroll();
        setupAnimations();
    });
</script>

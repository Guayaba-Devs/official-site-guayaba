---
import { Image } from "astro:assets";
import logoGuayaba from "@/assets/images/guayaba-cover.png";
---

<header
    class="bg-linear-to-r from-primary to-secondary fixed top-0 w-screen z-30"
>
    <nav
        class="mx-auto flex items-center justify-between px-2 h-[4rem] lg:px-8"
    >
        <div class="flex items-center justify-between w-full">
            <Image
                src={logoGuayaba}
                alt="Guayaba Devs Logo"
                width={200}
                height={60}
                class="pr-8"
            />
            <ul class="flex space-x-12 font-semibold">
                <li><a href="#nosotros">Nosotros</a></li>
                <li><a href="#servicios">Miembros</a></li>
                <li><a href="#contacto">Newsletter</a></li>
                <li><a href="#contacto">Posts</a></li>
                <li><a href="#contacto">FAQ</a></li>
            </ul>
        </div>
    </nav>
</header>
